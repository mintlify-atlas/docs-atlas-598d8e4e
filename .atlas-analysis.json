  "publicApiSurface": [
    "Provider trait - AI model provider interface",
    "Channel trait - Messaging platform interface",
    "Tool trait - Agent capability interface",
    "Memory trait - Storage backend interface",
    "RuntimeAdapter trait - Execution environment interface",
    "Observer trait - Observability interface",
    "SecurityPolicy - Security and access control",
    "IdentityConfig - Agent identity configuration",
    "corvus agent - Interactive chat command",
    "corvus gateway - Webhook server command",
    "corvus daemon - Autonomous runtime command",
    "corvus onboard - Setup wizard command",
